{
  "buildCommand": "npm install -g pnpm && pnpm install && pnpm --filter @workspace/api-server run build",
  "outputDirectory": "artifacts/expiry-scan-app/dist/public",
  "installCommand": "echo 'install handled in buildCommand'",
  "functions": {
    "api/index.js": {
      "includeFiles": "artifacts/api-server/dist/vercel.cjs",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/:path*", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/email/weekly-report",
      "schedule": "0 20 * * 0"
    }
  ]
}
